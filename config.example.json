{
  "email": {
    "smtp_server": "smtp.gmail.com",
    "smtp_port": 465,
    "sender_email": "your-email@gmail.com",
    "sender_name": "每日拾光学习簿",
    "sender_password": "YOUR_APP_PASSWORD_OR_SMTP_TOKEN",
    "recipients": {
      "server": {
        "email": "your-email@gmail.com",
        "target_name": "开发者Sammy"
      },
      "student_a": {
        "email": "recipient@example.com",
        "target_name": "学员A"
      },
      "student_b": {
        "email": "another-recipient@example.com",
        "target_name": "学员B"
      }
    },
    "target_recipient_ids": [
      "student_a",
      "student_b"
    ],
    "failure_recipient_id": "server",
    "imap_server": "imap.gmail.com",
    "imap_port": 993,
    "imap_user": "your-email@gmail.com",
    "imap_password": "YOUR_APP_PASSWORD_OR_IMAP_TOKEN"
  },
  "schedule": {
    "daily_run_time": "09:00",
    "html_run_time": "09:00",
    "email_send_time": "09:30",
    "timezone": "Asia/Shanghai"
  },
  "repositories": [
    {
      "name": "DailyLearningAssistant",
      "path": "~/projects/DailyLearningAssistant"
    }
  ],
  "remote_repositories": [
    {
      "urls": [
        "git@github.com:your-name/private-notes.git",
        "https://github.com/your-name/private-notes.git"
      ],
      "refs": [
        "refs/heads/main"
      ],
      "enabled": false
    },
    {
      "name": "public-library",
      "urls": [
        "https://github.com/some-org/some-library.git"
      ],
      "refs": [
        "refs/heads/main",
        "refs/tags/v1.0.0"
      ],
      "enabled": false
    }
  ],
  "llm": {
    "api_url": "https://api.deepseek.com/v1/chat/completions",
    "api_key": "YOUR_DEEPSEEK_API_KEY",
    "model": "deepseek-v4-pro",
    "trust_env_proxy": false
  },
  "site": {
    "base_url": "https://yourgithubusername.github.io/DailyLearningAssistant"
  },
  "publish": {
    "remote": "origin",
    "branch": "main",
    "commit_message": "Publish daily learning report {date}",
    "paths": [
      "daily_report/{year_month}/{date}-learning-report.html",
      "daily_report/manifest.json",
      "knowledge_log/{year_month}-knowledge-log.md",
      "knowledge_log/{year_month}-question-threads.json",
      "knowledge_log/manifest.json",
      "index.html"
    ]
  }
}
