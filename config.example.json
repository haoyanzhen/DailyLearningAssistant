{
  "email": {
    "smtp_server": "smtp.gmail.com",
    "smtp_port": 465,
    "sender_email": "your-email@gmail.com",
    "sender_name": "每日拾光学习簿",
    "sender_password": "YOUR_APP_PASSWORD_OR_SMTP_TOKEN",
    "target_emails": [
      "recipient@example.com",
      "another-recipient@example.com"
    ],
    "disabled_target_emails": [],
    "imap_server": "imap.gmail.com",
    "imap_port": 993,
    "imap_user": "your-email@gmail.com",
    "imap_password": "YOUR_APP_PASSWORD_OR_IMAP_TOKEN"
  },
  "schedule": {
    "daily_run_time": "09:00",
    "html_run_time": "09:00",
    "email_send_time": "09:30",
    "timezone": "Asia/Shanghai"
  },
  "repositories": [
    {
      "name": "DailyLearningAssistant",
      "path": "~/projects/DailyLearningAssistant"
    }
  ],
  "llm": {
    "api_url": "https://api.deepseek.com/v1/chat/completions",
    "api_key": "YOUR_DEEPSEEK_API_KEY",
    "model": "deepseek-v4-pro"
  },
  "site": {
    "base_url": "https://yourgithubusername.github.io/DailyLearningAssistant"
  },
  "publish": {
    "remote": "origin",
    "branch": "main",
    "commit_message": "Publish daily learning report {date}",
    "paths": [
      "prework/{year_month}/{date}/work_summary_AInote.md",
      "prework/{year_month}/{date}/work_summary_DailyLearningAssistant.md",
      "prework/{year_month}/{date}/work_summary_interview_prepare.md",
      "prework/{year_month}/{date}/work_summary_mcp.md",
      "prework/{year_month}/{date}/work_summary_ResearchPaperBase_cc.md",
      "prework/{year_month}/{date}/work_summary_ResearchPaperBase_codex.md",
      "prework/{year_month}/{date}/concept_relevance.md",
      "prework/{year_month}/{date}/knowledge_explaination.md",
      "daily_report/{year_month}/{date}-learning-report.html",
      "daily_report/manifest.json",
      "knowledge_log/{year_month}-knowledge-log.md",
      "knowledge_log/manifest.json",
      "index.html"
    ]
  }
}
